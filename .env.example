# ============================================================
# 阿凡达云控 - 环境变量示例
# ============================================================
# 复制此文件为 .env 并修改配置
# ============================================================

# -------------------- 应用配置 --------------------
FLASK_DEBUG=false
SECRET_KEY=your-super-secret-key-here-change-in-production
WEB_HOST=0.0.0.0
WEB_PORT=8899
LOG_LEVEL=INFO

# -------------------- 数据库配置 --------------------
# SQLite (默认)
DB_TYPE=sqlite
SQLITE_PATH=data/textnow_factory.db

# MySQL (如需使用 MySQL)
# DB_TYPE=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=textnow
# DB_PASS=your-password
# DB_NAME=textnow_us

# -------------------- 代理配置 --------------------
# 如需通过代理访问 TextNow，取消下面的注释并修改为你的代理地址
# TN_PROXY=socks5h://127.0.0.1:1080

# -------------------- 矩阵群发配置 --------------------
MATRIX_THREADS=4
MATRIX_BATCH_SIZE=50